<style>
  :root {
    --bg: #f7f6f3;
    --surface: #ffffff;
    --border: #e4e2dc;
    --text: #2b2a27;
    --text-muted: #8a877f;
    --unread: #b26a2f;
    --unread-bg: #f6ecdf;
    --read: #3a7d5a;
    --read-bg: #e5f0ea;
    --danger: #c0392b;
  }

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  body {
    font-family: "Hiragino Kaku Gothic ProN", "Yu Gothic", "Meiryo", sans-serif;
    background: var(--bg);
    color: var(--text);
    line-height: 1.6;
    padding: 2rem 1rem;
  }

  .container {
    max-width: 640px;
    margin: 0 auto;
  }

  .back {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.875rem;
    margin-bottom: 1.25rem;
  }

  .back:hover {
    color: var(--text);
  }

  h1 {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 1.25rem;
  }

</style>
<div class="container">
  <%= link_to "← 一覧に戻る", books_path, class: "back" %>
  <h1>蔵書編集</h1>

  <%= render "form", book: @book, submit_label: "更新する", cancel_url: book_path(@book) %>
</div>
