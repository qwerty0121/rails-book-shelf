<style>
  :root {
    --bg: #f7f6f3;
    --surface: #ffffff;
    --border: #e4e2dc;
    --text: #2b2a27;
    --text-muted: #8a877f;
    --unread: #b26a2f;
    --unread-bg: #f6ecdf;
    --read: #3a7d5a;
    --read-bg: #e5f0ea;
    --danger: #c0392b;
  }

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  body {
    font-family: "Hiragino Kaku Gothic ProN", "Yu Gothic", "Meiryo", sans-serif;
    background: var(--bg);
    color: var(--text);
    line-height: 1.6;
    padding: 2rem 1rem;
  }

  .container {
    max-width: 640px;
    margin: 0 auto;
  }

  .back {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.875rem;
    margin-bottom: 1.25rem;
  }

  .back:hover {
    color: var(--text);
  }

  h1 {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 1.25rem;
  }

  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.75rem;
  }

  .field {
    margin-bottom: 1.4rem;
  }

  .field__label {
    display: block;
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 0.45rem;
  }

  .required {
    color: var(--danger);
    font-size: 0.75rem;
    margin-left: 0.25rem;
  }

  input[type="text"],
  textarea {
    width: 100%;
    font: inherit;
    color: var(--text);
    background: #fbfaf8;
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.6rem 0.75rem;
  }

  input[type="text"]:focus,
  textarea:focus {
    outline: none;
    border-color: var(--read);
    background: #fff;
  }

  textarea {
    resize: vertical;
    min-height: 6rem;
  }

  .radio-group {
    display: flex;
    gap: 0.75rem;
  }

  .radio {
    flex: 1;
    position: relative;
  }

  .radio input {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
  }

  .radio span {
    display: block;
    text-align: center;
    font-size: 0.9rem;
    font-weight: 600;
    padding: 0.55rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    cursor: pointer;
    color: var(--text-muted);
  }

  .radio input:checked + span {
    border-color: var(--read);
    background: var(--read-bg);
    color: var(--read);
  }

  .radio input:focus-visible + span {
    outline: 2px solid var(--read);
    outline-offset: 2px;
  }

  .error {
    display: none;
    color: var(--danger);
    font-size: 0.8rem;
    margin-top: 0.35rem;
  }

  .field.has-error input {
    border-color: var(--danger);
  }

  .field.has-error .error {
    display: block;
  }

  .actions {
    display: flex;
    gap: 0.75rem;
    margin-top: 1.75rem;
  }

  .btn {
    font: inherit;
    font-weight: 600;
    border-radius: 8px;
    padding: 0.6rem 1.25rem;
    cursor: pointer;
    border: 1px solid transparent;
  }

  .btn--primary {
    background: var(--read);
    color: #fff;
  }

  .btn--primary:hover {
    background: #326b4d;
  }

  .btn--ghost {
    background: transparent;
    border-color: var(--border);
    color: var(--text);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
  }

  .btn--ghost:hover {
    background: #fbfaf8;
  }

  .btn:focus-visible {
    outline: 2px solid var(--read);
    outline-offset: 2px;
  }

  .toast {
    display: none;
    background: var(--read-bg);
    color: var(--read);
    border: 1px solid #cfe3d8;
    border-radius: 8px;
    padding: 0.75rem 1rem;
    font-size: 0.9rem;
    margin-bottom: 1.25rem;
  }
</style>
<div class="container">
  <%= link_to "← 一覧に戻る", books_path, class: "back" %>
  <h1>蔵書登録</h1>

  <form class="card" novalidate>
    <div class="field">
      <label class="field__label" for="title">タイトル<span class="required">必須</span></label>
      <input type="text" name="title" autocomplete="off" placeholder="例：リーダブルコード">
      <p class="error">タイトルを入力してください。</p>
    </div>

    <div class="field">
      <label class="field__label" for="author">著者名<span class="required">必須</span></label>
      <input type="text" name="author" autocomplete="off" placeholder="例：Dustin Boswell">
      <p class="error">著者名を入力してください。</p>
    </div>

    <div class="field">
      <span class="field__label">読了状態</span>
      <div class="radio-group">
        <label class="radio">
          <input type="radio" name="status" value="未読" checked>
          <span>未読</span>
        </label>
        <label class="radio">
          <input type="radio" name="status" value="読了済">
          <span>読了済</span>
        </label>
      </div>
    </div>

    <div class="field">
      <label class="field__label" for="memo">メモ</label>
      <textarea name="memo" placeholder="任意で入力できます"></textarea>
    </div>

    <div class="actions">
      <button type="submit" class="btn btn--primary">登録する</button>
      <%= link_to "キャンセル", books_path, class: "btn btn--ghost" %>
    </div>
  </form>
</div>
